<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F19">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#151A28"
        app:tabMode="scrollable"
        app:tabTextColor="#808B96"
        app:tabSelectedTextColor="#00E5FF"
        app:tabIndicatorColor="#00E5FF"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.tabs.TabItem android:text="1. Binder" />
        <com.google.android.material.tabs.TabItem android:text="2. Deck" />
        <com.google.android.material.tabs.TabItem android:text="3. Cheat Sheets" />
        <com.google.android.material.tabs.TabItem android:text="4. Whiteboard" />
        <com.google.android.material.tabs.TabItem android:text="5. My Brain" />
    </com.google.android.material.tabs.TabLayout>

    <FrameLayout
        android:id="@+id/container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tabLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/viewBinder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <Button
                android:id="@+id/btnSnapNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:backgroundTint="#7000FF"
                android:text="⚡ Snap &amp; Scan Note" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerBinder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerDeck"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <ScrollView
            android:id="@+id/viewCheatSheet"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/textCheatSheet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
        </ScrollView>

        <LinearLayout
            android:id="@+id/viewWhiteboard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <Button
                android:id="@+id/btnClearCanvas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Erase Whiteboard"
                android:backgroundTint="#FF4C4C" />

            <com.example.digitalbinder.DrawingView
                android:id="@+id/drawingCanvas"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/viewAnalytics"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/textStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#00E5FF"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center" />
        </LinearLayout>

    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>